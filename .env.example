# Used by native Windows or venv runs.
DB_PATH=data/jobs.db

# Used by the worker in both Docker and native runs.
SCRAPE_INTERVAL_HOURS=6

# Drop listings older than this many days when scraping.
MAX_JOB_AGE_DAYS=30

# Dashboard default scope: crypto-only or all-remote-design.
DASHBOARD_SCOPE_DEFAULT=all-remote-design
